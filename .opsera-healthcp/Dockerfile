# ════════════════════════════════════════════════════════════════════════════
# HEALTHCP - CI/CD Infrastructure Dockerfile
# Multi-stage build for React + Vite application
# Generated by Opsera Code-to-Cloud Enterprise v0.934
# RULE 74: Uses nginx-unprivileged for non-root security
# RULE 6: NODE_ENV scoped to runtime only (not set during npm install)
# Build context: . (repo root) - source code lives at repo root
# ════════════════════════════════════════════════════════════════════════════

# Stage 1: Build
# RULE 6: Do NOT set NODE_ENV here - allows devDependencies (vite, tsc) to install
FROM node:20-alpine AS builder

WORKDIR /app

# Copy package files first for better layer caching
COPY package*.json ./
COPY bun.lockb* ./

# RULE 73: Use --legacy-peer-deps for compatibility
# devDependencies (vite, typescript, etc.) MUST be installed for build step
RUN npm install --legacy-peer-deps

# Copy source code (build context = repo root)
COPY src/ ./src/
COPY public/ ./public/
COPY index.html ./
COPY vite.config.ts ./
COPY tsconfig*.json ./
COPY tailwind.config.ts ./
COPY postcss.config.js ./
COPY components.json ./

# Build the application
RUN npm run build

# Stage 2: Production
# RULE 74: Use nginx-unprivileged for runAsNonRoot security contexts
# RULE 74b: Port 8080 for non-privileged execution
FROM nginxinc/nginx-unprivileged:alpine AS production

# Copy custom nginx config (listens on 8080 for non-root)
# nginx.conf is in repo root (build context), conf.d can only have server{} blocks
COPY nginx.conf /etc/nginx/conf.d/default.conf

# Copy built assets from builder stage
COPY --from=builder /app/dist /usr/share/nginx/html

# Add healthcheck on port 8080
HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
  CMD wget --no-verbose --tries=1 --spider http://localhost:8080/health || exit 1

# Expose port 8080 (non-privileged port, RULE 74b)
EXPOSE 8080

# nginx-unprivileged runs as non-root by default (uid 101)
