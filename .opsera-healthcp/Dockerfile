# ════════════════════════════════════════════════════════════════════════════
# Dockerfile - healthcp
# Generated by Opsera Code-to-Cloud Enterprise v0.934
# App: React + TypeScript + Vite frontend
# RULE 6: NODE_ENV scoped to runtime only (never before npm install)
# RULE 7: Build context = . (repo root), source code lives there
# RULE 74: nginxinc/nginx-unprivileged:alpine (non-root, port 8080)
# ════════════════════════════════════════════════════════════════════════════

# ── Stage 1: Build ──────────────────────────────────────────────────────────
FROM node:22-alpine AS build

WORKDIR /app

# Install dependencies first (NODE_ENV must NOT be set here)
# This ensures devDependencies (vite, typescript, etc.) are installed
COPY package*.json ./
RUN npm ci --ignore-scripts

# Copy source and build
COPY . .
RUN npm run build

# ── Stage 2: Runtime (non-root nginx) ────────────────────────────────────────
FROM nginxinc/nginx-unprivileged:alpine AS runtime

# Copy nginx config (server {} block only — no pid directive, RULE 3)
# nginx.conf is at repo root (build context .), goes to conf.d/
COPY nginx.conf /etc/nginx/conf.d/default.conf

# Copy built assets from build stage
COPY --from=build /app/dist /usr/share/nginx/html

# Non-privileged port (RULE 74b)
EXPOSE 8080

CMD ["nginx", "-g", "daemon off;"]
