# Opsera Code-to-Cloud Enterprise v0.934
# .dockerignore for hcp-0305
# Build context is repo root — exclude unnecessary files from Docker context

# Dependencies (will be reinstalled in Docker)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build output (will be rebuilt in Docker)
dist/
build/

# Git
.git/
.gitignore

# CI/CD infrastructure (not needed in container)
.opsera-hcp-0305/
.github/

# Test files
coverage/
*.test.ts
*.test.tsx
*.spec.ts
*.spec.tsx
vitest.config.ts

# Dev config
.env.local
.env.development
.env.test
*.local

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
